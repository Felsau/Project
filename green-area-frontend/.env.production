# Production build flags (Create React App reads this on `npm run build`).
#
# INLINE_RUNTIME_CHUNK=false — keep the webpack runtime as an EXTERNAL
# /static/js file instead of an inline <script>. Required so the enforced
# Content-Security-Policy (`script-src 'self'`, see netlify.toml / vercel.json)
# doesn't block the app's bootstrap. With the default (true), CRA inlines the
# runtime as an inline script which a strict CSP rejects → blank page.
INLINE_RUNTIME_CHUNK=false
