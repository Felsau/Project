{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/data/**",
              "components/feedback/**",
              "components/forms/**",
              "components/layout/**",
              "ui_kits/dashboard/**",
              "ui_kits/landing/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Sarabun|Inter|IBM Plex Sans Thai|IBM Plex Mono))/i]",
        "message": "Font not provided by the design system. Available: Sarabun, Inter, IBM Plex Sans Thai, IBM Plex Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='BrandMark'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|withWordmark|label|key|ref|className|style|children)$/]",
        "message": "<BrandMark> doesn't accept that prop. Declared props: size, withWordmark, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|full|disabled|onClick|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, full, disabled, onClick, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|primary|text)$/]",
        "message": "<Button> variant must be one of 'default' | 'primary' | 'text'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm)$/]",
        "message": "<Button> size must be one of 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|disabled|onClick|children|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: active, disabled, onClick, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='ExportBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:buttons|busy|onAction|title|key|ref|className|style|children)$/]",
        "message": "<ExportBar> doesn't accept that prop. Declared props: buttons, busy, onAction, title."
      },
      {
        "selector": "JSXOpeningElement[name.name='Field'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|value|onChange|placeholder|type|disabled|key|ref|className|style|children)$/]",
        "message": "<Field> doesn't accept that prop. Declared props: id, value, onChange, placeholder, type, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='Figure'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|unit|tag|progress|key|ref|className|style|children)$/]",
        "message": "<Figure> doesn't accept that prop. Declared props: value, unit, tag, progress."
      },
      {
        "selector": "JSXOpeningElement[name.name='MapLegend'] > JSXAttribute > JSXIdentifier[name!=/^(?:mode|title|gradient|min|max|showEmpty|key|ref|className|style|children)$/]",
        "message": "<MapLegend> doesn't accept that prop. Declared props: mode, title, gradient, min, max, showEmpty."
      },
      {
        "selector": "JSXOpeningElement[name.name='MapLegend'] > JSXAttribute[name.name='mode'] > Literal[value!=/^(?:ndvi|lst)$/]",
        "message": "<MapLegend> mode must be one of 'ndvi' | 'lst'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Section'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|key|ref|className|style|children)$/]",
        "message": "<Section> doesn't accept that prop. Declared props: children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tabs'] > JSXAttribute > JSXIdentifier[name!=/^(?:tabs|active|onChange|key|ref|className|style|children)$/]",
        "message": "<Tabs> doesn't accept that prop. Declared props: tabs, active, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|children|onDismiss|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: type, children, onDismiss."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:info|error)$/]",
        "message": "<Toast> type must be one of 'info' | 'error'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TopBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|subtitle|source|sourceMeta|loading|theme|sidebarCollapsed|onBrandClick|onShowAbout|onToggleTheme|onToggleSidebar|key|ref|className|style|children)$/]",
        "message": "<TopBar> doesn't accept that prop. Declared props: title, subtitle, source, sourceMeta, loading, theme, sidebarCollapsed, onBrandClick, onShowAbout, onToggleTheme, onToggleSidebar."
      },
      {
        "selector": "JSXOpeningElement[name.name='TopBar'] > JSXAttribute[name.name='theme'] > Literal[value!=/^(?:light|dark)$/]",
        "message": "<TopBar> theme must be one of 'light' | 'dark'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
