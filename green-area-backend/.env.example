SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your-supabase-service-role-key-here
GEE_PROJECT=your-gee-project-id

# CORS — dev ใช้ localhost · production ต้องเปลี่ยนเป็น URL จริง
# (Vercel/Netlify ของ frontend) คั่นด้วย comma ถ้ามีหลาย origin
# ตัวอย่าง: ALLOWED_ORIGINS=https://green-area.vercel.app,https://staging.example.com
ALLOWED_ORIGINS=http://localhost:3000

# ตั้ง ADMIN_TOKEN เพื่อเปิดใช้ DELETE /cache (ส่งผ่าน header X-Admin-Token: <token>)
# ถ้าไม่ตั้ง endpoint จะ reject ทุก request
# ⚠️ production: ต้องเป็น secret สุ่มยาว ≥ 16 ตัว ไม่งั้น backend จะ refuse start
ADMIN_TOKEN=change-me-to-a-random-secret

# Optional · ระดับ log (DEBUG / INFO / WARNING / ERROR) — default INFO
# LOG_LEVEL=INFO

# Optional · rate limit ต่อ IP (slowapi format) — default 60/minute
# เช่น "30/minute", "1000/hour" · หลัง proxy ต้องใช้ --proxy-headers (ดู README)
# RATE_LIMIT=60/minute

# Optional · ปี WorldPop ที่ใช้คำนวณ pop_need ใน /recommend
# Default 2020 (ปีล่าสุดที่มีใน WorldPop/GP/100m/pop ของ GEE)
# WORLDPOP_YEAR=2020

# Optional · path ไป thailand.json และ thailand_districts.json
# Backend จะหาตามลำดับ:
#   1) ENV override ด้านล่าง (ถ้าตั้ง)
#   2) green-area-backend/data/ (production-friendly · วางไฟล์เข้า image)
#   3) ../green-area-frontend/public/ (dev local แบบ monorepo)
# THAILAND_GEOJSON_PATH=/app/data/thailand.json
# DISTRICTS_GEOJSON_PATH=/app/data/thailand_districts.json
