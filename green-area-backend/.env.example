SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your-supabase-anon-key-here
GEE_PROJECT=your-gee-project-id
ALLOWED_ORIGINS=http://localhost:3000
# ตั้งค่า ADMIN_TOKEN เพื่อเปิดใช้ DELETE /cache (ส่งผ่าน header X-Admin-Token)
# ถ้าไม่ตั้งค่า endpoint จะคืน 503 และไม่สามารถเรียกได้
ADMIN_TOKEN=change-me-to-a-random-secret
